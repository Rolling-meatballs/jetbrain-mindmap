{
  "name": "vscode-mindmap",
  "displayName": "vscode-mindmap",
  "icon": "resources/icon.png",
  "description": "mindmap for vscode",
  "version": "0.0.5",
  "publisher": "Souche",
  "repository": {
    "type": "git",
    "url": "https://github.com/souche/vscode-mindmap.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:xmind",
    "onLanguage:km",
    "onCommand:extension.mindmap"
  ],
  "main": "./out/extension",
  "contributes": {
    "languages": [
      {
        "id": "km",
        "extensions": [
          ".km"
        ],
        "aliases": [
          "KM",
          "km"
        ]
      },
      {
        "id": "xmind",
        "extensions": [
          ".xmind"
        ],
        "aliases": [
          "XMIND",
          "xmind"
        ]
      }
    ],
    "commands": [
      {
        "command": "extension.mindmap",
        "title": "mindmap"
      }
    ],
    "keybindings": [
      {
        "command": "extension.mindmap",
        "key": "ctrl+m",
        "mac": "cmd+m",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "vite build",
    "watch": "vite build --watch",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "xmind": "^2.2.33"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^10.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}

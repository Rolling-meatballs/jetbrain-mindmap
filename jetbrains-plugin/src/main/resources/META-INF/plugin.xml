<idea-plugin>
    <id>com.souche.mindmap.idea</id>
    <name>Mindmap</name>
    <vendor email="dev@souche.com" url="https://github.com/souche/vscode-mindmap">Souche</vendor>

    <description><![CDATA[
      Mind map and XMind editor plugin with a JCEF-based bridge.
      Current scope: open and edit .km/.xmind files, import XMind content with styles and images, save .km files, and export PNG images.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Mindmap"
                  implementationClass="com.souche.mindmap.idea.MindmapFileType"
                  fieldName="INSTANCE"
                  language="TEXT"
                  extensions="km;xmind"/>
        <toolWindow id="Mindmap" anchor="right" factoryClass="com.souche.mindmap.idea.MindmapToolWindowFactory" canCloseContents="false"/>
        <fileEditorProvider implementation="com.souche.mindmap.idea.MindmapFileEditorProvider"/>
        <projectService serviceImplementation="com.souche.mindmap.idea.MindmapProjectState"/>
        <postStartupActivity implementation="com.souche.mindmap.idea.MindmapStartupActivity"/>
        <notificationGroup id="Mindmap Notifications" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>

    <actions>
        <action id="Mindmap.OpenCurrentFile"
                class="com.souche.mindmap.idea.OpenMindmapAction"
                text="Open Mindmap"
                description="Open current .km/.xmind file in Mindmap tool window">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl M"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta M"/>
        </action>
    </actions>
</idea-plugin>
